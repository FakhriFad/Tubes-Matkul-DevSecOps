# ============================================================
# EcomShop – .gitignore
# ============================================================

# ── Secrets & Environment ─────────────────────────────────
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# ── TLS Certificates (generate with nginx/generate-certs.sh) ──
nginx/ssl/
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Node.js ───────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ── Next.js ───────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel/

# ── Build outputs ─────────────────────────────────────────
dist/
build/
*.tsbuildinfo
frontend/next-env.d.ts

# ── Test & Coverage ───────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Logs ──────────────────────────────────────────────────
logs/
*.log

# ── Docker ────────────────────────────────────────────────
docker-compose.override.yml

# ── OS & Editor ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ── Misc ──────────────────────────────────────────────────
.cache/
tmp/
temp/
